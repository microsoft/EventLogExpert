@using EventLogExpert.Shared.Base
@inherits ModalBase<bool>

<ModalChrome AriaLabel="Saved Filters"
    CloseLabel="Exit"
    Footer="FooterPreset.ImportExportClose"
    InlineAlert="@CurrentInlineAlert"
    OnClose="OnCancelAsync"
    OnDialogClosedByUser="HandleDialogClosedByUserAsync"
    OnExport="OnExportAsync"
    OnImport="OnImportAsync"
    OnInlineAlertResolved="HandleInlineAlertResolvedAsync"
    @ref="ChromeRef">
    <ChildContent>
        <div class="flex-column-scroll">
            @if (FilterCacheState.Value.FavoriteFilters.Any())
            {
                <div id="favorite-filters-heading">Favorite Filters</div>
                <div aria-labelledby="favorite-filters-heading" role="list">
                    @foreach (var filter in FilterCacheState.Value.FavoriteFilters)
                    {
                        <div class="flex-space-between" role="listitem">
                            <div>
                                <button aria-label="@($"Remove {filter} from favorites")" class="button button-yellow"
                                    @onclick="() => RemoveFavorite(filter)"
                                    type="button">
                                    <i aria-hidden="true" class="bi bi-star-fill"></i>
                                </button>
                                <span>@filter</span>
                            </div>

                            <button aria-label="@($"Apply filter {filter}")" class="button button-green"
                                @onclick="() => AddFilter(filter)"
                                type="button">
                                <i aria-hidden="true" class="bi bi-plus-circle"></i>
                            </button>
                        </div>
                    }
                </div>

                <hr class="divider" />
            }

            @if (FilterCacheState.Value.RecentFilters.Any())
            {
                <div id="recent-filters-heading">Recent Filters</div>
                <div aria-labelledby="recent-filters-heading" role="list">
                    @foreach (var filter in FilterCacheState.Value.RecentFilters)
                    {
                        <div class="flex-space-between" role="listitem">
                            <div>
                                <button aria-label="@($"Add {filter} to favorites")" class="button button-yellow"
                                    @onclick="() => AddFavorite(filter)"
                                    type="button">
                                    <i aria-hidden="true" class="bi bi-star"></i>
                                </button>
                                <span>@filter</span>
                            </div>

                            <button aria-label="@($"Apply filter {filter}")" class="button button-green"
                                @onclick="() => AddFilter(filter)"
                                type="button">
                                <i aria-hidden="true" class="bi bi-plus-circle"></i>
                            </button>
                        </div>
                    }
                </div>
            }
            else
            {
                <p>No Recent Filters</p>
            }
        </div>
    </ChildContent>
</ModalChrome>
