<dialog aria-label="@(string.IsNullOrEmpty(Title) ? (string.IsNullOrEmpty(AriaLabel) ? "Dialog" : AriaLabel) : null)"
    aria-labelledby="@(string.IsNullOrEmpty(Title) ? null : _titleId)"
    aria-modal="true"
    class="@DialogClass"
    @oncancel="HandleCancelEventAsync"
    @oncancel:preventDefault="true"
    @onclose="HandleCloseEventAsync"
    @onkeydown:stopPropagation="true"
    @onkeyup:stopPropagation="true"
    @ref="_dialogRef"
    style="@DialogInlineStyle">
    <div class="dialog-group">
        @if (!string.IsNullOrEmpty(Title))
        {
            <header class="dialog-header" inert="@HasInlineAlert">
                <h2 class="dialog-title" id="@_titleId">@Title</h2>

                @if (ShowCloseButton)
                {
                    <button aria-label="@(string.IsNullOrEmpty(CloseButtonAriaLabel) ? "Close" : CloseButtonAriaLabel)"
                        class="button dialog-close"
                        disabled="@HasInlineAlert"
                        @onclick="HandleCloseButtonAsync"
                        type="button">
                        <i aria-hidden="true" class="bi bi-x"></i>
                    </button>
                }
            </header>
        }

        <div class="dialog-body" inert="@HasInlineAlert">
            @ChildContent
        </div>

        <div class="footer-group" inert="@HasInlineAlert">
            @if (ExtraFooterContent is not null)
            {
                <div class="footer-extra">
                    @ExtraFooterContent
                </div>
            }

            @switch (Footer)
            {
                case FooterPreset.CloseOnly:
                    <button autofocus
                        class="button"
                        disabled="@HasInlineAlert"
                        @onclick="HandleCloseButtonAsync"
                        type="button">
                        @CloseLabel
                    </button>
                    break;

                case FooterPreset.SaveCancel:
                    <div class="button-group">
                        <button class="button button-green"
                            disabled="@HasInlineAlert"
                            @onclick="HandleSaveAsync"
                            type="button">
                            @SaveLabel
                        </button>
                        <button autofocus
                            class="button"
                            disabled="@HasInlineAlert"
                            @onclick="HandleCancelButtonAsync"
                            type="button">
                            @CancelLabel
                        </button>
                    </div>
                    break;

                case FooterPreset.ImportExportClose:
                    <div class="button-group">
                        <button class="button"
                            disabled="@HasInlineAlert"
                            @onclick="HandleImportAsync"
                            type="button">
                            @ImportLabel
                        </button>
                        <button class="button"
                            disabled="@HasInlineAlert"
                            @onclick="HandleExportAsync"
                            type="button">
                            @ExportLabel
                        </button>
                    </div>

                    <button autofocus
                        class="button"
                        disabled="@HasInlineAlert"
                        @onclick="HandleCloseButtonAsync"
                        type="button">
                        @CloseLabel
                    </button>
                    break;

                case FooterPreset.Dismiss:
                    <button autofocus
                        class="button"
                        disabled="@HasInlineAlert"
                        @onclick="HandleAcceptAsync"
                        type="button">
                        @AcceptLabel
                    </button>
                    break;

                case FooterPreset.AcceptCancel:
                    <button autofocus
                        class="button button-green"
                        disabled="@HasInlineAlert"
                        @onclick="HandleAcceptAsync"
                        type="button">
                        @AcceptLabel
                    </button>
                    <button class="button"
                        disabled="@HasInlineAlert"
                        @onclick="HandleCancelButtonAsync"
                        type="button">
                        @CancelLabel
                    </button>
                    break;
            }
        </div>
    </div>

    @if (HasInlineAlert)
    {
        <div aria-hidden="true" class="inline-alert-overlay"></div>

        <section aria-describedby="@_inlineAlertMessageId"
            aria-labelledby="@(string.IsNullOrEmpty(InlineAlert!.Title) ? null : _inlineAlertTitleId)"
            aria-label="@(string.IsNullOrEmpty(InlineAlert!.Title) ? "Alert" : null)"
            aria-modal="true"
            class="inline-alert"
            role="alertdialog">
            @if (!string.IsNullOrEmpty(InlineAlert.Title))
            {
                <h3 class="inline-alert-title" id="@_inlineAlertTitleId">@InlineAlert.Title</h3>
            }

            <p class="inline-alert-message" id="@_inlineAlertMessageId">@InlineAlert.Message</p>

            @if (InlineAlert.IsPrompt)
            {
                <input aria-label="@(string.IsNullOrEmpty(InlineAlert.Title) ? InlineAlert.Message : InlineAlert.Title)"
                    class="inline-alert-input"
                    @bind="_inlineAlertPromptValue"
                    @bind:event="oninput"
                    @ref="_inlineAlertInputRef"
                    type="text" />
            }

            <div class="inline-alert-buttons">
                @if (!string.IsNullOrEmpty(InlineAlert.AcceptLabel))
                {
                    <button autofocus="@(!InlineAlert.IsPrompt)"
                        class="button button-green"
                        @onclick="HandleInlineAlertAcceptAsync"
                        @ref="_inlineAlertAcceptButtonRef"
                        type="button">
                        @InlineAlert.AcceptLabel
                    </button>
                }
                <button autofocus="@(string.IsNullOrEmpty(InlineAlert.AcceptLabel))"
                    class="button"
                    @onclick="HandleInlineAlertCancelAsync"
                    @ref="_inlineAlertCancelButtonRef"
                    type="button">
                    @InlineAlert.CancelLabel
                </button>
            </div>
        </section>
    }
</dialog>
