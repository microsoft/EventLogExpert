@*
    Application root. The hybrid shell is intentionally non-routed: there are no @page directives anywhere.
    BannerHost lives outside UnhandledExceptionHandler so the error banner survives when child rendering faults.
*@
<BannerHost />

<UnhandledExceptionHandler>
    <Fluxor.Blazor.Web.StoreInitializer />

    <MainLayout />
</UnhandledExceptionHandler>
