      "version": 1,
      "filters": [
        {
          "comparison": { "property": "Source", "value": "Microsoft-Windows-WHEA-Logger" },
          "predicates": [
            { "comparison": { "property": "Id", "matchMode": "Many", "values": [ "1", "18" ] } }
          ]
        }
      ]
    },
