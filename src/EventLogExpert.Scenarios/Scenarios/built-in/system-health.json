      "order": 15,
      "version": 1,
      "filters": [
        {
          "comparison": { "property": "Source", "value": "Microsoft-Windows-Kernel-Power" },
          "predicates": [
            { "comparison": { "property": "Id", "matchMode": "Many", "values": [ "42", "107", "109" ] } }
