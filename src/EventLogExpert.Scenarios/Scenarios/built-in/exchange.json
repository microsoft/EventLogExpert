        {
          "comparison": { "property": "Source", "value": "MSExchangeRepl" },
          "predicates": [
            { "comparison": { "property": "Id", "matchMode": "Many", "values": [ "2153", "4074", "4099", "4113" ] } }
          ]
        }
      ]
    },
    {
      "id": "exchange-adaccess-failures",
      "name": "Exchange ADAccess (topology) failures",
