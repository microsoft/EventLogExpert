      "group": "ActiveDirectory",
      "channels": [ "System" ],
      "requiresAdmin": false,
      "priority": 1,
      "order": 6,
      "version": 1,
      "filters": [
        {
          "comparison": { "property": "Source", "value": "Microsoft-Windows-Kerberos-Key-Distribution-Center" },
          "predicates": [
            { "comparison": { "property": "Id", "matchMode": "Many", "values": [ "39", "41" ] } }
