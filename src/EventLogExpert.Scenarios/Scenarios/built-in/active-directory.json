      "version": 1,
      "filters": [
        {
          "comparison": { "property": "Id", "matchMode": "Many", "values": [ "1206", "1401" ] },
          "predicates": [
            { "joinWithAny": true, "comparison": { "property": "Level", "matchMode": "Many", "values": [ "Critical", "Error" ] } }
          ]
