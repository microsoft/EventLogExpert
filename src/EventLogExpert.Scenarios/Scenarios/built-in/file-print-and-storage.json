      "channels": [ "Security" ],
      "requiresAdmin": true,
      "priority": 1,
      "order": 20,
      "version": 1,
      "filters": [
        { "color": "Green", "comparison": { "property": "Id", "value": "5142" } },
        { "color": "Blue", "comparison": { "property": "Id", "value": "5143" } },
        { "color": "Red", "comparison": { "property": "Id", "value": "5144" } }
      ]
