<article class="library-entry" data-entry-id="@Entry.Id">
    <div class="library-entry-row-main">
        <i aria-label="@KindAriaLabel" class="@KindIconClass" role="img"></i>

        @if (Entry is LibraryEntryFilterSet)
        {
            <button aria-controls="@_filterEditorRegionId"
                aria-expanded="@(_isExpanded ? "true" : "false")"
                aria-label="@($"Filters for {Entry.Name}")"
                class="button icon-button library-entry-expand-toggle"
                @onclick="ToggleExpand"
                type="button">
                <i aria-hidden="true" class="@(_isExpanded ? "bi bi-chevron-down" : "bi bi-chevron-right")"></i>
            </button>
        }

        <div class="library-entry-name">
            <span class="library-entry-name-text" title="@Entry.Name">@Entry.Name</span>
            @if (Entry is LibraryEntryFilterSet filterSet)
            {
                <span class="library-entry-detail">(@filterSet.Filters.Count filter@(filterSet.Filters.Count == 1 ? "" : "s"))</span>
            }
            @if (ActiveTab == LibraryTab.PreviouslyUsed)
            {
                <span aria-label="Automatically added from recent use"
                    class="library-entry-tracked-badge"
                    title="Automatically added from recent use">
                    Tracked
                </span>

                @if (Entry.LastUsedUtc is { } lastUsed)
                {
                    <span class="library-entry-detail">@FormatRelativeTime(lastUsed)</span>
                }
            }
        </div>

        @if (Entry.Tags.Count > 0 && !_isEditingTags)
        {
            <div class="library-entry-tag-chips-inline-wrapper">
                <div class="library-entry-tag-chips-inline" role="list">
                    @{
                        var inlineVisible = Math.Min(Entry.Tags.Count, InlineTagChipCap);
                        var inlineHidden = Entry.Tags.Count - inlineVisible;
                    }
                    @for (int i = 0; i < inlineVisible; i++)
                    {
                        <span class="library-entry-tag-chip" role="listitem">@Entry.Tags[i]</span>
                    }
                </div>
                @if (inlineHidden > 0)
                {
                    <button aria-label="@($"Show all {Entry.Tags.Count} tags")"
                        class="button library-entry-tag-chip-more"
                        @onclick="ToggleEditTagsMode"
                        title="@string.Join(", ", Entry.Tags.Skip(inlineVisible))"
                        type="button">
                        +@inlineHidden more
                    </button>
                }
            </div>
        }

        <button aria-label="@($"Apply {Entry.Name} additively to current filters")"
            class="button button-green"
            @onclick="OnApplyAsync"
            type="button">
            <i aria-hidden="true" class="bi bi-plus-circle"></i> Apply
        </button>

        @if (IsFavoritable)
        {
            <button aria-label="@FavoriteAriaLabel"
                aria-pressed="@(Entry.IsFavorite ? "true" : "false")"
                class="button button-yellow icon-button"
                @onclick="OnToggleFavoriteAsync"
                title="@FavoriteTitle"
                type="button">
                <i aria-hidden="true" class="@FavoriteIconClass"></i>
            </button>
        }

        <button aria-expanded="@(IsMoreMenuOpen ? "true" : "false")"
            aria-haspopup="menu"
            aria-label="@($"More actions for {Entry.Name}")"
            class="button icon-button"
            @onclick="ToggleMoreMenuAsync"
            @ref="_moreMenuButtonRef"
            title="More actions"
            type="button">
            <i aria-hidden="true" class="bi bi-three-dots-vertical"></i>
        </button>
    </div>

    @if (_isEditingTags || Entry.Tags.Count == 0)
    {
        <div class="library-entry-row-tags-edit">
            @if (_isEditingTags)
            {
                <TagPicker AriaLabel="@($"Tags for {Entry.Name}")"
                    SuggestionSource="@AllLibraryTags"
                    Value="@Entry.Tags"
                    ValueChanged="@OnTagsChangedAsync" />

                <button aria-label="Done editing tags"
                    class="button icon-button library-entry-tags-done"
                    @onclick="ToggleEditTagsMode"
                    title="Done"
                    type="button">
                    <i aria-hidden="true" class="bi bi-check2"></i>
                </button>
            }
            else
            {
                <button aria-label="@($"Add tags to {Entry.Name}")"
                    class="button library-entry-tags-add"
                    @onclick="ToggleEditTagsMode"
                    type="button">
                    <i aria-hidden="true" class="bi bi-plus"></i> Add tags
                </button>
            }
        </div>
    }

    @if (Entry is LibraryEntryFilterSet expandedSet && _isExpanded)
    {
        <div class="library-entry-row-expanded" id="@_filterEditorRegionId">
            <LibraryEntryFilterEditor FilterSet="@expandedSet" IsExpanded="true" />
        </div>
    }
</article>
