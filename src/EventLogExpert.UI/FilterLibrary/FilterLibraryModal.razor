@inherits ModalBase<bool>

<ModalChrome AriaLabel="Filter Library"
    BodyLayout="ModalBodyLayout.Flex"
    Footer="FooterPreset.ImportExportClose"
    Height="80%"
    InlineAlert="@CurrentInlineAlert"
    MaxWidth="min(80rem, calc(100vw - 2rem))"
    MinWidth="min(80rem, calc(100vw - 2rem))"
    OnClose="OnCancelAsync"
    OnDialogClosedByUser="HandleDialogClosedByUserAsync"
    OnExport="OnExportAsync"
    OnImport="OnImportAsync"
    OnInlineAlertResolved="HandleInlineAlertResolvedAsync"
    @ref="ChromeRef"
    Title="Filter Library">
    <ChildContent>
        @if (FilterLibraryState.Value.LoadError)
        {
            <div class="filter-library-error" role="alert">
                <p>Could not load saved filters or filter sets. See trace log for details.</p>
                <button class="button" @onclick="RetryLoad" type="button">Retry</button>
            </div>
        }
        else if (!FilterLibraryState.Value.IsLoaded)
        {
            <p aria-busy="true" class="filter-library-loading">Loading filter library&hellip;</p>
        }
        else
        {
            <SidebarTabs @bind-ActiveTab="_activeTab"
                IsTabpanelFocusable="@IsTabpanelEmpty"
                @ref="_sidebarTabsRef"
                TablistAriaLabel="Filter library views"
                Tabs="@CurrentTabLabels"
                TTab="LibraryTab">
                <TabContent Context="tab">
                    @switch (tab)
                    {
                        case LibraryTab.Saved:
                            @if (SavedDirectEntries.Count == 0 && SavedSectionTree.Count == 0)
                            {
                                <p class="library-empty-state">@GetEmptyStateMessage(tab)</p>
                            }
                            else
                            {
                                @foreach (var section in SavedSectionTree)
                                {
                                    <LibraryEntrySection ChildSections="@section.ChildSections"
                                        DirectEntries="@section.DirectEntries"
                                        EntryTemplate="@(entry => RenderEntryRow(tab, entry))"
                                        SectionName="@section.SectionName" />
                                }

                                @foreach (var entry in SavedDirectEntries)
                                {
                                    @RenderEntryRow(tab, entry)
                                }
                            }

                            break;
                        case LibraryTab.Favorites:
                            @if (FavoriteEntries.Count == 0)
                            {
                                <p class="library-empty-state">@GetEmptyStateMessage(tab)</p>
                            }
                            else
                            {
                                @foreach (var entry in FavoriteEntries) { @RenderEntryRow(tab, entry) }
                            }

                            break;
                        case LibraryTab.PreviouslyUsed:
                            @if (PreviouslyUsedEntries.Count == 0)
                            {
                                <p class="library-empty-state">@GetEmptyStateMessage(tab)</p>
                            }
                            else
                            {
                                @foreach (var entry in PreviouslyUsedEntries) { @RenderEntryRow(tab, entry) }
                            }

                            break;
                    }
                </TabContent>
            </SidebarTabs>
        }
    </ChildContent>
</ModalChrome>

@code {
    private RenderFragment RenderEntryRow(LibraryTab tab, LibraryEntry entry) =>
        __builder =>
        {
            <LibraryEntryRow ActiveTab="@tab"
                AllFilterSets="@AllFilterSets"
                Entry="@entry"
                @key="entry.Id"
                OnAddToFilterSet="@HandleAddToFilterSetAsync"
                OnApply="@HandleApplyAsync"
                OnDelete="@HandleDelete"
                OnExportEntry="@HandleExportEntryAsync"
                OnReplace="@HandleReplaceAsync"
                OnRequestPendingFocus="@(id => HandleRequestPendingFocusAsync(tab, id))"
                OnSaveToLibrary="@HandleSaveToLibrary"
                OnToggleFavorite="@HandleToggleFavorite"
                @ref="_rowRefs[(tab, entry.Id)]" />
        };
}
