<div class="library-entry-filter-editor">
    @if (IsExpanded)
    {
        <div class="library-entry-filter-editor-list" id="@_filterListId">
            @if (FilterSet.Filters.Count == 0 && _pendingDrafts.Count == 0)
            {
                <p class="library-entry-filter-editor-empty">No filters in this set.</p>
            }

            @foreach (var saved in FilterSet.Filters)
            {
                <LibraryFilterRow Id="@ComponentId.For(saved.Id, ComponentIdScope.LibraryFilter).Value"
                    @key="saved.Id"
                    OnExclusionChanged="@(e => OnExclusionChangedForSaved(saved.Id, e))"
                    OnRemove="@(() => OnRemoveSaved(saved.Id))"
                    OnSave="@(updated => OnSaveSavedFilter(saved.Id, updated))"
                    OnToggleEnabled="@(() => OnToggleEnabledForSaved(saved.Id))"
                    Value="saved" />
            }

            @foreach (var draft in _pendingDrafts)
            {
                <LibraryFilterRow Id="@ComponentId.For(draft.Id, ComponentIdScope.LibraryPendingFilter).Value"
                    @key="draft.Id"
                    OnPendingDiscard="@(() => DiscardPendingDraft(draft))"
                    OnPendingSave="@(built => SavePendingDraft(draft, built))"
                    PendingDraft="draft" />
            }

            <button class="button library-entry-filter-editor-add-button"
                @onclick="AddPendingDraft"
                type="button">
                <i aria-hidden="true" class="bi bi-plus"></i> Add filter
            </button>
        </div>
    }
</div>
