@using EventLogExpert.Logging.Abstractions
@using Microsoft.Extensions.Logging
@inherits ModalBase<bool>

<ModalChrome AriaLabel="Debug Log"
    BodyLayout="ModalBodyLayout.Flex"
    CloseLabel="Exit"
    Footer="FooterPreset.CloseOnly"
    Height="60%"
    InlineAlert="@CurrentInlineAlert"
    MaxWidth="100rem"
    MinWidth="100rem"
    OnClose="OnCancelAsync"
    OnDialogClosedByUser="HandleDialogClosedByUserAsync"
    OnInlineAlertResolved="HandleInlineAlertResolvedAsync"
    @ref="ChromeRef">
    <ChildContent>
        <div aria-label="Filters" class="debug-log-filter-bar" role="group">
            <label>Level</label>
            <ComparisonOperatorSelect AriaLabel="Level operator"
                MatchMode="_levelMatchMode"
                OnChanged="HandleLevelChoiceChanged"
                Operator="_levelOperator"
                SupportsMany="true" />
            @if (_levelMatchMode == MatchMode.Many)
            {
                <ValueSelect AriaLabel="Levels"
                    CssClass="input filter-dropdown debug-log-level-multi"
                    EmptyText="All"
                    IsMultiSelect
                    T="LogLevel"
                    ToStringFunc="@(x => x.ToString())"
                    Values="_multiLevels"
                    ValuesChanged="HandleMultiLevelsChanged">
                    <ValueSelectItem ClearItem T="LogLevel">All</ValueSelectItem>
                    @foreach (var level in s_logLevels)
                    {
                        <ValueSelectItem T="LogLevel" Value="level" />
                    }
                </ValueSelect>
            }
            else
            {
                <ValueSelect AriaLabel="Level"
                    CssClass="input filter-dropdown"
                    T="LogLevel?"
                    ToStringFunc="@(x => x?.ToString() ?? "All")"
                    Value="_singleLevel"
                    ValueChanged="HandleSingleLevelChanged">
                    <ValueSelectItem ClearItem T="LogLevel?">All</ValueSelectItem>
                    @foreach (var level in s_logLevels)
                    {
                        <ValueSelectItem T="LogLevel?" Value="level" />
                    }
                </ValueSelect>
            }
            <label>Category</label>
            <ValueSelect AriaLabel="Categories"
                CssClass="input filter-dropdown debug-log-category-multi"
                EmptyText="All"
                IsMultiSelect
                T="string"
                ToStringFunc="@(x => x)"
                Values="_selectedCategories"
                ValuesChanged="HandleCategoriesChanged">
                <ValueSelectItem ClearItem T="string">All</ValueSelectItem>
                @foreach (var category in CategoryOptions())
                {
                    <ValueSelectItem T="string" Value="category" />
                }
            </ValueSelect>
            <label>Process</label>
            <ValueSelect AriaLabel="Process origin"
                CssClass="input filter-dropdown"
                T="ProcessOrigin?"
                ToStringFunc="@(ProcessOriginLabel)"
                Value="_processOriginFilter"
                ValueChanged="HandleProcessOriginChanged">
                <ValueSelectItem ClearItem T="ProcessOrigin?">All</ValueSelectItem>
                <ValueSelectItem T="ProcessOrigin?" Value="ProcessOrigin.InProcess" />
                <ValueSelectItem T="ProcessOrigin?" Value="ProcessOrigin.ElevatedHelper" />
            </ValueSelect>
            <input aria-label="Filter messages"
                class="debug-log-text-filter input"
                @oninput="HandleStringFilterInput"
                placeholder="Filter messages..."
                type="text"
                value="@_pendingStringFilter" />
        </div>
        <div aria-busy="@(_hasLoaded ? "false" : "true")" aria-label="Debug log entries" class="debug-log-viewport" role="region" tabindex="0">
            <Virtualize Context="line" Items="_displayedView" ItemSize="@RowHeightPx" OverscanCount="20">
                <ItemContent>
                    <div class="debug-log-row" title="@line">@line</div>
                </ItemContent>
                <EmptyContent>
                    @if (_hasLoaded)
                    {
                        <span>@(_entries.Count == 0 ? "Log is Empty..." : "No entries match filters.")</span>
                    }
                </EmptyContent>
            </Virtualize>
        </div>
    </ChildContent>
    <ExtraFooterContent>
        <div class="debug-log-footer">
            <div class="debug-log-footer-actions debug-log-footer-left">
                <Button Disabled="@(!_hasLoaded || _filteredEntryCount == 0)"
                    OnClick="HandleExportAsync">
                    Export
                </Button>
                <Button Disabled="@(!_hasLoaded || _filteredEntryCount == 0)"
                    OnClick="HandleCopyAsync">
                    Copy
                </Button>
            </div>
            <span aria-atomic="true" aria-live="polite" class="debug-log-footer-counter" role="status">
                @($"{_filteredEntryCount:N0} of {_entries.Count:N0} {(_entries.Count == 1 ? "entry" : "entries")}")
            </span>
            <div class="debug-log-footer-actions debug-log-footer-right">
                <Button OnClick="Refresh">Refresh</Button>
                <Button OnClick="Clear">Clear</Button>
            </div>
        </div>
    </ExtraFooterContent>
</ModalChrome>
