@inherits ModalBase<bool>

<ModalChrome AriaLabel="Debug Log"
    BodyLayout="ModalBodyLayout.Flex"
    CloseLabel="Exit"
    Footer="FooterPreset.CloseOnly"
    Height="60%"
    InlineAlert="@CurrentInlineAlert"
    MaxWidth="min(100rem, calc(100vw - 2rem))"
    MinWidth="min(100rem, calc(100vw - 2rem))"
    OnClose="OnCancelAsync"
    OnDialogClosedByUser="HandleDialogClosedByUserAsync"
    OnInlineAlertResolved="HandleInlineAlertResolvedAsync"
    @ref="ChromeRef">
    <ChildContent>
        <div aria-label="Filters" class="debug-log-filter-tray" role="group">
            @foreach (var filter in _filters)
            {
                <DebugLogFilterRow AvailableCategories="CategoryFilterOptions()"
                    Draft="filter"
                    IsEditing="_editingFilterId == filter.Id"
                    @key="filter.Id"
                    OnChanged="OnFilterChanged"
                    OnDone="CollapseEditor"
                    OnEdit="@(() => StartEditing(filter.Id))"
                    OnRemove="@(() => RemoveFilter(filter))"
                    @ref="_editorRefs[filter.Id]" />
            }

            <Button aria-label="@(CanAddFilter ? "Add filter" : "Finish the current filter before adding another")"
                CssClass="debug-log-add-filter"
                Disabled="@(!CanAddFilter)"
                IconClass="bi bi-plus-circle"
                OnClick="AddFilter"
                @ref="_addButton"
                title="@(CanAddFilter ? "Add filter" : "Finish the current filter before adding another")">
                Add Filter
            </Button>
        </div>
        <div aria-busy="@(_hasLoaded ? "false" : "true")" aria-label="Debug log entries" class="debug-log-viewport" role="region" tabindex="0">
            <Virtualize Context="line" Items="_displayedView" ItemSize="@RowHeightPx" OverscanCount="20">
                <ItemContent>
                    <div class="debug-log-row" title="@line">@line</div>
                </ItemContent>
                <EmptyContent>
                    @if (_hasLoaded)
                    {
                        <span>@(_entries.Count == 0 ? "Log is Empty..." : "No entries match filters.")</span>
                    }
                </EmptyContent>
            </Virtualize>
        </div>
    </ChildContent>
    <ExtraFooterContent>
        <div class="debug-log-footer">
            <div class="debug-log-footer-actions debug-log-footer-left">
                <Button Disabled="@(!_hasLoaded || _filteredEntryCount == 0)"
                    OnClick="HandleExportAsync">
                    Export
                </Button>
                <Button Disabled="@(!_hasLoaded || _filteredEntryCount == 0)"
                    OnClick="HandleCopyAsync">
                    Copy
                </Button>
            </div>
            <span aria-atomic="true" aria-live="polite" class="debug-log-footer-counter" role="status">
                @($"{_filteredEntryCount:N0} of {_entries.Count:N0} {(_entries.Count == 1 ? "entry" : "entries")}")
            </span>
            <div class="debug-log-footer-actions debug-log-footer-right">
                <Button OnClick="Refresh">Refresh</Button>
                <Button OnClick="Clear">Clear</Button>
            </div>
        </div>
    </ExtraFooterContent>
</ModalChrome>
