@using EventLogExpert.Runtime.DebugLog
@if (Draft is { } draft)
{
    <div class="debug-log-filter-editor">
        <Button aria-label="@(draft.IsExcluded ? "Filter is excluded; activate to include" : "Filter is included; activate to exclude")"
            aria-pressed="@(draft.IsExcluded ? "true" : "false")"
            CssClass="debug-log-filter-exclude-toggle"
            data-excluded="@(draft.IsExcluded ? "true" : "false")"
            IconClass="@(draft.IsExcluded ? "bi bi-slash-circle-fill" : "bi bi-slash-circle")"
            IconOnly
            OnClick="OnEditorExcludeToggled"
            @ref="_editorFirstControl"
            title="@(draft.IsExcluded ? "Excluded - click to include" : "Included - click to exclude")" />

        <ValueSelect AriaLabel="Filter field"
            CssClass="input filter-dropdown"
            T="DebugLogFilterField"
            ToStringFunc="@(field => field.ToString())"
            Value="draft.Field"
            ValueChanged="OnFieldChanged">
            @foreach (var field in Enum.GetValues<DebugLogFilterField>())
            {
                <ValueSelectItem T="DebugLogFilterField" Value="field" />
            }
        </ValueSelect>

        <ComparisonOperatorSelect AriaLabel="Filter operator"
            MatchMode="draft.MatchMode"
            OnChanged="OnOperatorChanged"
            Operator="draft.Operator"
            SupportsMany="FieldSupportsMany"
            SupportsText="FieldSupportsText" />

        @if (draft.Field == DebugLogFilterField.Message)
        {
            <TextInput AriaLabel="Filter value"
                CssClass="input filter-description"
                Value="@SingleValue"
                ValueChanged="OnSingleValueChanged" />
        }
        else if (draft.MatchMode == MatchMode.Many)
        {
            <ValueSelect AriaLabel="Filter value"
                CssClass="input filter-multiselect-dropdown"
                EmptyText="Any"
                IsMultiSelect
                T="string"
                ToStringFunc="@ValueLabel"
                Values="draft.Values"
                ValuesChanged="OnValuesChanged">
                <ValueSelectItem ClearItem T="string">Any</ValueSelectItem>
                @foreach (var option in ValueOptions())
                {
                    <ValueSelectItem T="string" Value="option" />
                }
            </ValueSelect>
        }
        else
        {
            <ValueSelect AriaLabel="Filter value"
                CssClass="input filter-value-dropdown"
                T="string"
                ToStringFunc="@ValueLabel"
                Value="@SingleValue"
                ValueChanged="OnSingleValueChanged">
                <ValueSelectItem ClearItem T="string">Any</ValueSelectItem>
                @foreach (var option in ValueOptions())
                {
                    <ValueSelectItem T="string" Value="option" />
                }
            </ValueSelect>
        }

        <Button aria-label="Save filter"
            Disabled="@(!draft.IsComplete)"
            IconClass="bi bi-check-circle"
            IconOnly
            OnClick="OnSave"
            title="@(draft.IsComplete ? "Save filter" : "Add a value to finish this filter")" />

        <Button aria-label="Cancel edit"
            IconClass="bi bi-x-circle"
            IconOnly
            OnClick="OnCancel"
            title="Cancel edit" />

        @if (Applied is not null)
        {
            <DangerButton aria-label="Remove filter"
                IconClass="bi bi-dash-circle"
                IconOnly
                OnClick="OnRemove"
                title="Remove filter" />
        }
    </div>
}
else if (Applied is { } applied)
{
    var summary = FilterSummary(applied);

    <div class="debug-log-filter-chip" data-disabled="@(applied.IsEnabled ? "false" : "true")">
        <Button aria-label="@(applied.IsExcluded ? "Filter is excluded; activate to include" : "Filter is included; activate to exclude")"
            aria-pressed="@(applied.IsExcluded ? "true" : "false")"
            CssClass="debug-log-filter-exclude-toggle"
            data-excluded="@(applied.IsExcluded ? "true" : "false")"
            IconClass="@(applied.IsExcluded ? "bi bi-slash-circle-fill" : "bi bi-slash-circle")"
            IconOnly
            OnClick="OnExcludeToggled"
            title="@(applied.IsExcluded ? "Excluded - click to include" : "Included - click to exclude")" />

        <Button aria-label="@(applied.IsEnabled ? "Filter is enabled; activate to disable" : "Filter is disabled; activate to enable")"
            aria-pressed="@(applied.IsEnabled ? "true" : "false")"
            CssClass="debug-log-filter-enable-toggle"
            data-enabled="@(applied.IsEnabled ? "true" : "false")"
            IconClass="@(applied.IsEnabled ? "bi bi-toggle-on" : "bi bi-toggle-off")"
            IconOnly
            OnClick="OnEnableToggled"
            title="@(applied.IsEnabled ? "Enabled - click to disable" : "Disabled - click to enable")" />

        <ChromelessButton aria-label="@($"Edit filter: {summary}")"
            CssClass="debug-log-filter-chip-edit"
            OnClick="OnEdit"
            @ref="_chipEditButton"
            title="Edit filter">
            <span class="debug-log-filter-summary" title="@summary">@summary</span>
        </ChromelessButton>

        <ChromelessButton aria-label="@($"Remove filter: {summary}")"
            CssClass="debug-log-filter-chip-remove"
            IconClass="bi bi-x-circle"
            OnClick="OnRemove"
            title="Remove filter" />
    </div>
}
