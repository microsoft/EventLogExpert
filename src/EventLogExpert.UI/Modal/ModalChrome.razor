<dialog aria-label="@(string.IsNullOrEmpty(Title) ? (string.IsNullOrEmpty(AriaLabel) ? "Dialog" : AriaLabel) : null)"
    aria-labelledby="@(string.IsNullOrEmpty(Title) ? null : _titleId)"
    aria-modal="true"
    class="@DialogClass"
    data-body-layout="@BodyLayout.ToString().ToLowerInvariant()"
    @oncancel="HandleCancelEventAsync"
    @oncancel:preventDefault="true"
    @onclose="HandleCloseEventAsync"
    @onkeydown:stopPropagation="true"
    @onkeyup:stopPropagation="true"
    @ref="_dialogRef"
    style="@DialogInlineStyle">
    <div class="dialog-group">
        <div class="banner-region" inert="@HasInlineAlert">
            <BannerHost Location="BannerHostLocation.InsideModal" />
        </div>

        @if (!string.IsNullOrEmpty(Title))
        {
            <header class="dialog-header" inert="@HasInlineAlert">
                <h2 class="dialog-title" id="@_titleId" title="@Title">@Title</h2>

                @if (ShowCloseButton)
                {
                    <Button aria-label="@(string.IsNullOrEmpty(CloseButtonAriaLabel) ? "Close" : CloseButtonAriaLabel)"
                        CssClass="dialog-close"
                        Disabled="@HasInlineAlert"
                        IconClass="bi bi-x"
                        OnClick="HandleCloseButtonAsync" />
                }
            </header>
        }

        <div class="dialog-body" inert="@HasInlineAlert">
            @ChildContent
        </div>

        <div class="footer-group" inert="@HasInlineAlert">
            @if (ExtraFooterContent is not null)
            {
                <div class="footer-extra@(StackFooterExtra ? " footer-extra-stacked" : null)">
                    @ExtraFooterContent
                </div>
            }

            @switch (Footer)
            {
                case FooterPreset.CloseOnly:
                    <Button autofocus
                        Disabled="@(HasInlineAlert || FooterDisabled)"
                        OnClick="HandleCloseButtonAsync">
                        @CloseLabel
                    </Button>

                    break;

                case FooterPreset.SaveCancel:
                    <div class="button-group">
                        <PrimaryButton Disabled="@(HasInlineAlert || FooterDisabled)"
                            OnClick="HandleSaveAsync">
                            @SaveLabel
                        </PrimaryButton>
                        <Button Disabled="@(HasInlineAlert || FooterDisabled)"
                            OnClick="HandleCancelButtonAsync">
                            @CancelLabel
                        </Button>
                    </div>
                    break;

                case FooterPreset.ImportExportClose:
                    <div class="button-group">
                        <Button Disabled="@(HasInlineAlert || FooterDisabled)"
                            OnClick="HandleImportAsync">
                            @ImportLabel
                        </Button>
                        <Button Disabled="@(HasInlineAlert || FooterDisabled)"
                            OnClick="HandleExportAsync">
                            @ExportLabel
                        </Button>
                    </div>

                    <Button autofocus
                        Disabled="@(HasInlineAlert || FooterDisabled)"
                        OnClick="HandleCloseButtonAsync">
                        @CloseLabel
                    </Button>

                    break;

                case FooterPreset.Dismiss:
                    <Button autofocus
                        Disabled="@(HasInlineAlert || FooterDisabled)"
                        OnClick="HandleAcceptAsync">
                        @AcceptLabel
                    </Button>

                    break;

                case FooterPreset.AcceptCancel:
                    <PrimaryButton autofocus
                        Disabled="@(HasInlineAlert || FooterDisabled || AcceptDisabled)"
                        OnClick="HandleAcceptAsync">
                        @AcceptLabel
                    </PrimaryButton>

                    <Button Disabled="@(HasInlineAlert || FooterDisabled)"
                        OnClick="HandleCancelButtonAsync">
                        @CancelLabel
                    </Button>

                    break;

                case FooterPreset.None:
                    break;
            }
        </div>
    </div>

    @if (HasInlineAlert)
    {
        <div aria-hidden="true" class="inline-alert-overlay"></div>

        <section aria-describedby="@_inlineAlertMessageId"
            aria-label="@(string.IsNullOrEmpty(InlineAlert!.Title) ? "Alert" : null)"
            aria-labelledby="@(string.IsNullOrEmpty(InlineAlert!.Title) ? null : _inlineAlertTitleId)"
            aria-modal="true"
            class="inline-alert"
            role="alertdialog">
            @if (!string.IsNullOrEmpty(InlineAlert.Title))
            {
                <h3 class="inline-alert-title" id="@_inlineAlertTitleId" title="@InlineAlert.Title">@InlineAlert.Title</h3>
            }

            <p class="inline-alert-message" id="@_inlineAlertMessageId">@InlineAlert.Message</p>

            @if (InlineAlert.IsPrompt)
            {
                <TextInput AriaDescribedBy="@(ValidationError is not null ? _inlineAlertValidationErrorId : null)"
                    AriaInvalid="@(ValidationError is not null)"
                    AriaLabelledBy="@_inlineAlertMessageId"
                    CssClass="input dialog-input"
                    @ref="_inlineAlertInput"
                    UpdateOnInput="true"
                    Value="@_inlineAlertPromptValue"
                    ValueChanged="HandleInlineAlertPromptValueChanged" />

                @if (ValidationError is not null)
                {
                    <p aria-live="polite"
                        class="inline-alert-validation-error"
                        id="@_inlineAlertValidationErrorId">
                        @ValidationError
                    </p>
                }
            }

            <div class="inline-alert-buttons">
                @if (!string.IsNullOrEmpty(InlineAlert.AcceptLabel))
                {
                    <PrimaryButton autofocus="@(!InlineAlert.IsPrompt)"
                        Disabled="@(ValidationError is not null)"
                        OnClick="HandleInlineAlertAcceptAsync"
                        @ref="_inlineAlertAcceptButton">
                        @InlineAlert.AcceptLabel
                    </PrimaryButton>
                }
                @if (!string.IsNullOrEmpty(InlineAlert.SecondaryActionLabel))
                {
                    <Button OnClick="HandleInlineAlertSecondaryAsync">
                        @InlineAlert.SecondaryActionLabel
                    </Button>
                }
                <Button autofocus="@(string.IsNullOrEmpty(InlineAlert.AcceptLabel))"
                    OnClick="HandleInlineAlertCancelAsync"
                    @ref="_inlineAlertCancelButton">
                    @InlineAlert.CancelLabel
                </Button>
            </div>
        </section>
    }

    @* In-dialog MenuHost so context menus and shortcut-triggered menus render
       in the top-layer stacking context of this <dialog>, not behind it. *@
    <MenuHost />
</dialog>
