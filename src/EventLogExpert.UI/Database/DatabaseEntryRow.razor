<div class="db-entry-row"
    @oncontextmenu="HandleContextMenuAsync"
    @oncontextmenu:preventDefault="true">
    <div @attributes="CheckboxHiddenAttributes"
        class="db-entry-checkbox @(IsSelectionModeActive ? "db-entry-checkbox--visible" : null)">
        <Checkbox AriaLabel="@($"Select {Entry.FileName}")"
            Disabled="@(!IsSelectionModeActive)"
            Value="IsSelected"
            ValueChanged="@(_ => OnSelectionToggle.InvokeAsync())" />
    </div>

    <div class="db-entry-row-content">
        <div class="db-entry-info">
            <button class="db-entry-name" id="@_nameButtonId" @ref="_nameButtonRef" type="button">@Entry.FileName</button>
            @if (ShouldShowBadge)
            {
                <span class="db-entry-badge" data-badge="@BadgeKind">@BadgeLabel</span>
            }
        </div>

        <div class="db-entry-actions @(ShowPendingIndicator ? "db-entry-actions--pending" : null)">
            @if (ShowPendingIndicator)
            {
                <span class="visually-hidden" id="@_pendingStatusId">(pending toggle, unsaved)</span>
            }

            @switch (PrimaryAction)
            {
                case ActionKind.Toggle:
                case ActionKind.DisabledToggle:
                    <OptionSelect AriaDescribedBy="@(ShowPendingIndicator ? _pendingStatusId : null)"
                        AriaLabelledBy="@_nameButtonId"
                        Disabled="@(PrimaryAction == ActionKind.DisabledToggle)"
                        UseStatusColors="true"
                        Value="EffectiveEnabled"
                        ValueChanged="@(_ => OnToggle.InvokeAsync())" />

                    break;

                case ActionKind.Spinner:
                    @if (UpgradeProgress is { } progress)
                    {
                        var verb = PhaseVerb(progress.CurrentPhase);
                        var hasFile = !string.IsNullOrEmpty(progress.CurrentEntryName);
                        var hasPosition = progress.CurrentBatchSize > 1;

                        var displayText = hasFile
                            ? (hasPosition ? $"{verb} {progress.CurrentBatchPosition} of {progress.CurrentBatchSize}" : verb)
                            : $"Preparing upgrade of {progress.CurrentBatchSize} {(progress.CurrentBatchSize == 1 ? "database" : "databases")}\u2026";

                        <span class="db-entry-upgrading">
                            <span class="db-entry-upgrading-status" role="status">
                                <i aria-hidden="true" class="bi bi-arrow-repeat db-entry-spinner"></i>
                                <span class="db-entry-upgrading-text" @key="verb">@displayText</span>
                                @if (hasFile)
                                {
                                    <span class="visually-hidden"> for @Entry.FileName</span>
                                }
                            </span>
                            <button class="button db-entry-cancel-btn" @onclick="OnCancelClick" type="button">
                                Cancel
                            </button>
                        </span>
                    }
                    else
                    {
                        <span class="db-entry-upgrading" role="status">
                            <i aria-hidden="true" class="bi bi-arrow-repeat db-entry-spinner"></i>
                            <span>Upgrading&hellip;</span>
                        </span>
                    }

                    break;

                case ActionKind.Upgrade:
                    <button aria-disabled="@(IsUpgradeBlocked ? "true" : "false")"
                        aria-label="@($"Upgrade database {Entry.FileName}")"
                        class="button db-entry-upgrade-btn"
                        @onclick="@(async () =>
                                  {
                                      if (!IsUpgradeBlocked) { await OnUpgrade.InvokeAsync(); }
                                  })"
                        type="button">
                        <i aria-hidden="true" class="bi bi-arrow-up-circle"></i> Upgrade
                    </button>
                    break;

                case ActionKind.Retry:
                    <button aria-disabled="@(IsUpgradeBlocked ? "true" : "false")"
                        aria-label="@($"Retry upgrade of database {Entry.FileName}")"
                        class="button button-red db-entry-upgrade-btn"
                        @onclick="@(async () =>
                                  {
                                      if (!IsUpgradeBlocked) { await OnUpgrade.InvokeAsync(); }
                                  })"
                        type="button">
                        <i aria-hidden="true" class="bi bi-arrow-clockwise"></i> Retry Upgrade
                    </button>
                    break;

                case ActionKind.RestoreFromBackup:
                    <button aria-disabled="@(IsRestoreBlocked ? "true" : "false")"
                        aria-label="@($"Restore database {Entry.FileName} from backup")"
                        class="button db-entry-restore-btn"
                        @onclick="@(async () =>
                                  {
                                      if (!IsRestoreBlocked) { await OnRestoreFromBackup.InvokeAsync(); }
                                  })"
                        type="button">
                        <i aria-hidden="true" class="bi bi-arrow-counterclockwise"></i> Restore
                    </button>
                    break;

                case ActionKind.RetryClassification:
                    <button aria-label="@($"Retry classification of database {Entry.FileName}")"
                        class="button db-entry-retry-classification-btn"
                        @onclick="@(async () => await OnRetryClassification.InvokeAsync())"
                        type="button">
                        <i aria-hidden="true" class="bi bi-arrow-repeat"></i> Retry classification
                    </button>
                    break;
            }
        </div>
    </div>
</div>
