@namespace EventLogExpert.UI.FilterEditor.Comparison

<ValueSelect AriaLabel="@(AriaLabelledBy is null ? AriaLabel ?? "Comparison" : null)"
    AriaLabelledBy="@AriaLabelledBy"
    CssClass="@CssClass"
    T="ComparisonKind"
    ToStringFunc="@(KindLabel)"
    Value="Current"
    ValueChanged="HandleKindChanged">
    <ValueSelectItem T="ComparisonKind" Value="ComparisonKind.Equals" />
    @if (SupportsText)
    {
        <ValueSelectItem T="ComparisonKind" Value="ComparisonKind.Contains" />
    }
    <ValueSelectItem T="ComparisonKind" Value="ComparisonKind.NotEqual" />
    @if (SupportsText)
    {
        <ValueSelectItem T="ComparisonKind" Value="ComparisonKind.NotContains" />
    }
    @if (SupportsMany)
    {
        <ValueSelectItem T="ComparisonKind" Value="ComparisonKind.MultiSelect" />
    }
</ValueSelect>
