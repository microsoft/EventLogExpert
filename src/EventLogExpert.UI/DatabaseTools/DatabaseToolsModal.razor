@using EventLogExpert.UI.DatabaseTools.Tabs
@inherits ModalBase<bool>

<ModalChrome AriaLabel="Database Tools"
    Footer="FooterPreset.CloseOnly"
    Height="80%"
    InlineAlert="@CurrentInlineAlert"
    MaxWidth="min(80rem, calc(100vw - 2rem))"
    MinWidth="min(80rem, calc(100vw - 2rem))"
    OnCancel="OnCancelAsync"
    OnClose="OnCancelAsync"
    OnDialogClosedByUser="HandleDialogClosedByUserAsync"
    OnInlineAlertResolved="HandleInlineAlertResolvedAsync"
    @ref="ChromeRef">
    <ChildContent>
        <CascadingValue Value="_verboseLogging" Name="VerboseLogging">
            <div class="database-tools">
                <div aria-orientation="vertical" class="database-tools-tabs" role="tablist">
                    @foreach (var (tab, label) in s_tabs)
                    {
                        <button aria-controls="@($"db-tabpanel-{tab}")"
                            aria-selected="@(tab == _activeTab ? "true" : "false")"
                            class="@(tab == _activeTab ? "tab active" : "tab")"
                            id="@($"db-tab-{tab}")"
                            @onclick="() => SetActiveTab(tab)"
                            @onkeydown="e => OnTabKeyDown(e, tab)"
                            @ref="_tabButtonRefs[tab]"
                            role="tab"
                            tabindex="@(tab == _activeTab ? "0" : "-1")"
                            type="button">
                            @label
                        </button>
                    }
                </div>

                <div class="database-tools-content">
                    @foreach (var (tab, _) in s_tabs)
                    {
                        <div aria-labelledby="@($"db-tab-{tab}")"
                            class="@(tab == _activeTab ? "tabpanel active" : "tabpanel")"
                            id="@($"db-tabpanel-{tab}")"
                            role="tabpanel"
                            style="@(tab == _activeTab ? "" : "display: none")">
                            @switch (tab)
                            {
                                case DatabaseToolsTab.Show:
                                    <ShowProvidersTab @ref="_showTab" />

                                    break;
                                case DatabaseToolsTab.Create:
                                    <CreateDatabaseTab @ref="_createTab" />

                                    break;
                                case DatabaseToolsTab.Merge:
                                    <MergeDatabaseTab @ref="_mergeTab" />

                                    break;
                                case DatabaseToolsTab.Diff:
                                    <DiffDatabasesTab @ref="_diffTab" />

                                    break;
                                case DatabaseToolsTab.Upgrade:
                                    <UpgradeDatabaseTab @ref="_upgradeTab" />

                                    break;
                            }
                        </div>
                    }
                </div>
            </div>
        </CascadingValue>
    </ChildContent>
    <ExtraFooterContent>
        <div class="verbose-mode" role="group" aria-labelledby="verbose-mode-label">
            <span class="verbose-mode-label" id="verbose-mode-label">Output</span>
            <ValueSelect T="bool"
                AriaDescribedBy="verbose-mode-help"
                AriaLabelledBy="verbose-mode-label"
                CssClass="input filter-dropdown verbose-mode-select"
                ToStringFunc="@(v => v ? "Verbose" : "Normal")"
                @bind-Value="_verboseLogging">
                <ValueSelectItem T="bool" Value="false">Normal</ValueSelectItem>
                <ValueSelectItem T="bool" Value="true">Verbose</ValueSelectItem>
            </ValueSelect>
            @* Kept as a visually-hidden span so screen readers still announce the help text on the dropdown. *@
            <span class="visually-hidden" id="verbose-mode-help">
                Verbose includes trace-level diagnostic details on next run.
            </span>
        </div>
    </ExtraFooterContent>
</ModalChrome>
