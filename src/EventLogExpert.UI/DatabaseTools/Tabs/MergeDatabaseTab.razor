@using EventLogExpert.DatabaseTools.MergeDatabase
@inherits DatabaseToolsTabBase<MergeDatabaseRequest>

<div class="db-tab merge-database-tab">
    <div class="db-tab-form">
        <div class="form-row">
            <label for="merge-source-path">Source</label>
            <div class="path-input-group">
                <span class="visually-hidden" id="merge-source-path-help">
                    Required. Path to a .db or .evtx whose providers will be merged into the target.
                </span>
                <input aria-describedby="merge-source-path-help"
                    class="input source-path"
                    disabled="@IsRunning"
                    id="merge-source-path"
                    @oninput="OnSourcePathInput"
                    placeholder="Path to .db or .evtx (paste a folder path to use a directory)"
                    type="text"
                    value="@_sourcePath" />
                <Button Disabled="@IsRunning" OnClick="PickSourceAsync">Browse…</Button>
            </div>
        </div>

        <div class="form-row">
            <label for="merge-target-path">Target .db</label>
            <div class="path-input-group">
                <span class="visually-hidden" id="merge-target-path-help">Required. Path to the existing target .db that will receive the merged providers.</span>
                <input aria-describedby="merge-target-path-help"
                    class="input target-path"
                    disabled="@IsRunning"
                    id="merge-target-path"
                    @oninput="OnTargetPathInput"
                    placeholder="C:\path\to\existing-database.db"
                    type="text"
                    value="@_targetPath" />
                <Button Disabled="@IsRunning" OnClick="PickTargetAsync">Browse…</Button>
            </div>
        </div>

        <div class="form-row">
            <label for="merge-overwrite-mode" id="merge-overwrite-mode-label">Existing providers</label>
            <ValueSelect AriaLabelledBy="merge-overwrite-mode-label"
                @bind-Value="_overwrite"
                CssClass="input filter-dropdown overwrite-mode-select"
                T="bool"
                ToStringFunc="FormatOverwriteMode">
                <ValueSelectItem T="bool" Value="false">@KeepModeLabel</ValueSelectItem>
                <ValueSelectItem T="bool" Value="true">@OverwriteModeLabel</ValueSelectItem>
            </ValueSelect>
        </div>

        <div class="form-row">
            <label for="merge-auto-import" id="merge-auto-import-label">When finished</label>
            <ValueSelect AriaLabelledBy="merge-auto-import-label"
                @bind-Value="AutoImportMode"
                CssClass="input"
                Id="merge-auto-import"
                T="AutoImportMode"
                ToStringFunc="FormatAutoImportMode">
                <ValueSelectItem T="AutoImportMode" Value="AutoImportMode.Off">Don't import</ValueSelectItem>
                <ValueSelectItem T="AutoImportMode" Value="AutoImportMode.Import">Import database</ValueSelectItem>
                <ValueSelectItem T="AutoImportMode" Value="AutoImportMode.ImportAndEnable">Import and enable</ValueSelectItem>
            </ValueSelect>
        </div>
    </div>

    <DatabaseToolsLogView Entries="@LogEntries" FileNamePrefix="merge-database" Outcome="@Outcome">
        <ToolbarLeadingContent>
            @if (IsRunning && !IsImportInProgress)
            {
                @if (IsCancelling)
                {
                    <Button Disabled IconClass="bi bi-hourglass-split">Cancelling…</Button>
                }
                else
                {
                    <DangerButton IconClass="bi bi-x-circle" OnClick="CancelRun">Cancel</DangerButton>
                }
            }
            else
            {
                <PrimaryButton Disabled="@(!CanRun || IsRunning || IsImportInProgress || IsConfirming)" IconClass="bi bi-play-fill" OnClick="RunAsync">Run</PrimaryButton>
            }
        </ToolbarLeadingContent>
        <ToolbarTrailingContent>
            @if (ShouldShowImportDatabaseButton)
            {
                <Button Disabled="@IsImportDatabaseButtonDisabled" IconClass="bi bi-database-add" OnClick="ImportProducedDatabaseAsync">
                    @ImportDatabaseButtonText
                </Button>
            }
        </ToolbarTrailingContent>
    </DatabaseToolsLogView>
</div>
