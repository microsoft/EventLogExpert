@using EventLogExpert.DatabaseTools.UpgradeDatabase
@inherits DatabaseToolsTabBase<UpgradeDatabaseRequest>

<div class="db-tab upgrade-database-tab">
    <div class="db-tab-form">
        <div class="form-row">
            <label for="upgrade-db-path">Database (.db)</label>
            <div class="path-input-group">
                <span class="visually-hidden" id="upgrade-db-path-help">Required. Path to the .db whose schema will be upgraded to the current version.</span>
                <input aria-describedby="upgrade-db-path-help"
                    class="input target-path"
                    disabled="@IsRunning"
                    id="upgrade-db-path"
                    @oninput="OnDbPathInput"
                    placeholder="C:\path\to\database.db"
                    type="text"
                    value="@_dbPath" />
                <Button Disabled="@IsRunning" OnClick="PickDbAsync">Browse…</Button>
            </div>
        </div>
    </div>

    <DatabaseToolsLogView Entries="@LogEntries" FileNamePrefix="upgrade-database" Outcome="@Outcome">
        <ToolbarLeadingContent>
            @if (IsRunning)
            {
                @if (IsCancelling)
                {
                    <Button Disabled IconClass="bi bi-hourglass-split">Cancelling…</Button>
                }
                else
                {
                    <DangerButton IconClass="bi bi-x-circle" OnClick="CancelRun">Cancel</DangerButton>
                }
            }
            else
            {
                <PrimaryButton Disabled="@(!CanRun)" IconClass="bi bi-play-fill" OnClick="RunAsync">Run</PrimaryButton>
            }
        </ToolbarLeadingContent>
    </DatabaseToolsLogView>
</div>
