@using EventLogExpert.DatabaseTools.ShowProviders
@inherits DatabaseToolsTabBase<ShowProvidersRequest>

<div class="db-tab show-providers-tab">
    <div class="db-tab-form">
        <div class="form-row">
            <label for="show-source-path">Source path</label>
            <div class="path-input-group">
                <span class="visually-hidden" id="show-source-path-help">
                    Optional. Leave empty to list local providers. Accepts a .db or .evtx path; paste a folder path to use a directory.
                </span>
                <input aria-describedby="show-source-path-help"
                    @bind-value="_sourcePath"
                    @bind-value:event="oninput"
                    class="input source-path"
                    disabled="@IsRunning"
                    id="show-source-path"
                    placeholder="Leave empty for local providers, or pick / paste a path"
                    type="text" />
                <Button Disabled="@IsRunning" OnClick="PickSourceAsync">Browse…</Button>
            </div>
        </div>

        <div class="form-row">
            <label for="show-filter">Filter (regex)</label>
            <span class="visually-hidden" id="show-filter-help">
                Optional regular expression. Provider names containing a match are included; anchor with ^ and $ for a full-string match.
            </span>
            <input aria-describedby="@(_filterError is null ? "show-filter-help" : "show-filter-help show-filter-error")"
                aria-invalid="@(_filterError is not null ? "true" : "false")"
                class="@FilterCssClass"
                disabled="@IsRunning"
                id="show-filter"
                @oninput="OnFilterInput"
                placeholder="e.g. ^Microsoft-.*"
                type="text"
                value="@_filterText" />

            @if (_filterError is not null)
            {
                <span class="filter-error" id="show-filter-error" role="alert">
                    <i aria-hidden="true" class="bi bi-exclamation-triangle"></i>
                    <span>@_filterError</span>
                </span>
            }
        </div>

        @if (ShowElevationWarning)
        {
            <div class="elevation-warning-slot">
                <div class="elevation-warning" role="alert">
                    <i aria-hidden="true" class="bi bi-shield-exclamation"></i>
                    <span>Running without elevation — some local providers (Security, etc.) will be skipped or return incomplete metadata.</span>
                    <Button Disabled="@IsRunning"
                        OnClick="RunElevatedAsync"
                        title="Run this operation in an elevated helper process; main app stays running.">
                        Run Elevated
                    </Button>
                </div>
            </div>
        }
    </div>

    <DatabaseToolsLogView Entries="@LogEntries" FileNamePrefix="show-providers" Outcome="@Outcome">
        <ToolbarLeadingContent>
            @if (IsRunning)
            {
                @if (IsCancelling)
                {
                    <Button Disabled>
                        <i aria-hidden="true" class="bi bi-hourglass-split"></i> Cancelling…
                    </Button>
                }
                else
                {
                    <DangerButton OnClick="CancelRun">
                        <i aria-hidden="true" class="bi bi-x-circle"></i> Cancel
                    </DangerButton>
                }
            }
            else
            {
                <PrimaryButton Disabled="@(!CanRun)" OnClick="RunAsync">
                    <i aria-hidden="true" class="bi bi-play-fill"></i> Run
                </PrimaryButton>
            }
        </ToolbarLeadingContent>
    </DatabaseToolsLogView>
</div>
