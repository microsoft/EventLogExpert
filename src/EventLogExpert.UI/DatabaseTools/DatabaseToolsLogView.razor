@implements IAsyncDisposable

<div class="database-tools-log-container">
    <div class="database-tools-log-toolbar">
        @if (ToolbarLeadingContent is not null)
        {
            <div class="toolbar-leading">@ToolbarLeadingContent</div>
        }

        <span class="entry-count">@Entries.Count @(Entries.Count == 1 ? "entry" : "entries")</span>

        <span aria-atomic="true" aria-live="@OutcomeChipAriaLive" role="@OutcomeChipRole">
            @if (Outcome is not null)
            {
                <span class="@OutcomeChipCss">
                    <i aria-hidden="true" class="@OutcomeChipIcon"></i> @OutcomeChipText
                </span>
            }
        </span>

        <div class="toolbar-trailing">
            @if (ToolbarTrailingContent is not null)
            {
                @ToolbarTrailingContent
            }

            <Button Disabled="@(Entries.Count == 0)" IconClass="bi bi-clipboard" OnClick="CopyAllAsync">
                Copy
            </Button>

            <Button Disabled="@(Entries.Count == 0)" IconClass="bi bi-download" OnClick="ExportAsync">
                Export
            </Button>

            @if (_showJumpToLatest)
            {
                <Button CssClass="jump-to-latest" IconClass="bi bi-arrow-down" OnClick="JumpToLatest">
                    Jump to latest
                </Button>
            }
        </div>
    </div>

    <div aria-live="polite"
        aria-relevant="additions"
        class="database-tools-log-view"
        @ref="_logViewRef"
        role="log">
        <Virtualize Context="entry" Items="Entries" ItemSize="20" OverscanCount="20">
            <ItemContent>
                <div class="log-entry @SeverityClass(entry.Level)">
                    <span class="log-timestamp">@entry.TimestampUtc.ToString("HH:mm:ss.fff")</span>
                    <span class="log-message" title="@entry.Message">@entry.Message</span>
                </div>
            </ItemContent>
            <EmptyContent>
                <div class="log-empty log-entry"><span class="log-message">No output.</span></div>
            </EmptyContent>
        </Virtualize>
    </div>
</div>
