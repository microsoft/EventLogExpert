@inherits InputComponent<bool>

<div aria-label="@(string.IsNullOrEmpty(AriaLabel) ? null : AriaLabel)" class="toggle" role="radiogroup">
    <input aria-label="@AriaLabel @DisabledString" checked="@(!Value)" disabled="@Disabled" id="@($"{Id}_false")" name="@Id" @onchange="UpdateValue" type="radio" value="false" />
    <label data-use-status-colors="@UseStatusColors.ToString().ToLower()" for="@($"{Id}_false")">@DisabledString</label>

    <input aria-label="@AriaLabel @EnabledString" checked="@(Value)" disabled="@Disabled" id="@($"{Id}_true")" name="@Id" @onchange="UpdateValue" type="radio" value="true" />
    <label data-use-status-colors="@UseStatusColors.ToString().ToLower()" for="@($"{Id}_true")">@EnabledString</label>
</div>
